<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Welcome{% endblock %}</title>

    {# Bootstrap CSS #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    {# Your custom CSS (if any) should come after Bootstrap to ensure overrides work #}
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
</head>
<body>
{% if app.user %}
    <div class="mb-3">
        You are logged in as {{ app.user.name }}, <a href="{{ path('app_logout') }}">Logout</a>
    </div>
{% endif %}
<header>
    {# Optional: Add a navbar or site header here #}
</header>

<main class="container">
    {% block body %}{% endblock %}
</main>

<footer class="text-center mt-5">
    <p>&copy; 2024 Your Website</p>
</footer>

{# Bootstrap JS #}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

{# Your custom JS (if any) should come after Bootstrap #}
<script src="{{ asset('js/scripts.js') }}"></script>
</body>
</html>
